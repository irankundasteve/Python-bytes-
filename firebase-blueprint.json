{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email address of the user." },
        "photoURL": { "type": "string", "format": "uri", "description": "The URL of the user's profile photo." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The role of the user." }
      },
      "required": ["uid", "email", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "A blog post or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the post." },
        "slug": { "type": "string", "description": "The URL-friendly slug for the post." },
        "content": { "type": "string", "description": "The full content of the post in Markdown." },
        "excerpt": { "type": "string", "description": "A short summary of the post." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "authorPhoto": { "type": "string", "description": "The photo URL of the author." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "A list of tags for the post." },
        "category": { "type": "string", "description": "The category of the post." },
        "videoUrl": { "type": "string", "format": "uri", "description": "An optional YouTube/Vimeo video URL." },
        "featuredImage": { "type": "string", "format": "uri", "description": "The URL of the featured image." },
        "isPublished": { "type": "boolean", "description": "Whether the post is published." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time the post was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The date and time the post was last updated." }
      },
      "required": ["title", "slug", "content", "authorId", "category", "isPublished", "createdAt"]
    },
    "Tutorial": {
      "title": "Tutorial",
      "description": "A Python tutorial series.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the tutorial." },
        "slug": { "type": "string", "description": "The URL-friendly slug for the tutorial." },
        "description": { "type": "string", "description": "A description of the tutorial." },
        "category": { "type": "string", "description": "The category of the tutorial." },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"], "description": "The difficulty level." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time the tutorial was created." }
      },
      "required": ["title", "slug", "category", "difficulty", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A category for posts and tutorials.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the category." },
        "slug": { "type": "string", "description": "The URL-friendly slug for the category." },
        "description": { "type": "string", "description": "A description of the category." }
      },
      "required": ["name", "slug"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "A newsletter subscriber.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The email address of the subscriber." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time the subscriber signed up." }
      },
      "required": ["email", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form message.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the sender." },
        "email": { "type": "string", "format": "email", "description": "The email address of the sender." },
        "subject": { "type": "string", "description": "The subject of the message." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date and time the message was sent." }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Blog posts."
    },
    "/tutorials/{tutorialId}": {
      "schema": "Tutorial",
      "description": "Tutorial series."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Content categories."
    },
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Newsletter subscribers."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Contact form messages."
    }
  }
}
